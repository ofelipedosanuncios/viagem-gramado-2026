# ===== Configuracao do Bot Guia Gramado 2026 =====
# Copie este arquivo para ".env" e preencha os valores.

# Token do seu bot no Telegram (pegue com o @BotFather)
TELEGRAM_TOKEN=cole_aqui_o_token_do_botfather

# Chave da API do Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=cole_aqui_a_chave_do_gemini

# (Opcional) URL do site da viagem. Ja vem com o padrao correto.
SITE_URL=https://ofelipedosanuncios.github.io/viagem-gramado-2026/

# (Opcional) Modelo do Gemini. Padrao gratuito recomendado: gemini-flash-lite-latest
GEMINI_MODEL=gemini-flash-lite-latest

# (Opcional) IDs do Telegram autorizados, separados por virgula.
# Deixe vazio para liberar pra qualquer pessoa que achar o bot.
# Ex.: TELEGRAM_ALLOWED_IDS=123456789,987654321
TELEGRAM_ALLOWED_IDS=
